{
  "name": "vsa-pipeline",
  "version": "1.0.0",
  "description": "Evaluation pipeline API for the VSA supplier assessment app",
  "main": "dist/api/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/api/server.js",
    "dev": "ts-node src/api/server.ts",
    "scrape:ares": "ts-node src/index.ts --source ares",
    "scrape:insolvency": "ts-node src/index.ts --source insolvency",
    "scrape:news": "ts-node src/index.ts --source news",
    "scrape:industry": "ts-node src/index.ts --source industry",
    "scrape:energy": "ts-node src/index.ts --source energy",
    "scrape:all": "ts-node src/index.ts --source all",
    "scrape:supplier": "ts-node src/scrape-supplier.ts",
    "test": "ts-node src/test-connection.ts"
  },
  "dependencies": {
    "@mendable/firecrawl-js": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "mongodb": "^6.3.0",
    "openai": "^4.20.0",
    "undici": "^7.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  }
}
